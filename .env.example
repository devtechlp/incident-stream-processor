MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=incidents
MONGO_COLLECTION=incidents

# URL of your incident-agent Azure Function HTTP trigger
FUNCTION_APP_URL=https://your-function-app.azurewebsites.net/api/processIncident

# Function App host key (from Azure portal → Function App → App keys)
FUNCTION_APP_KEY=your_function_app_host_key_here

LOG_LEVEL=info
