MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=incidents
MONGO_COLLECTION=incidents

# URL of your incident-agent Azure Function HTTP trigger
FUNCTION_APP_URL=https://your-function-app.azurewebsites.net/api/processIncident

# Function App host key (from Azure portal → Function App → App keys)
FUNCTION_APP_KEY=your_function_app_host_key_here

LOG_LEVEL=info

# HTTP server port for the Dynatrace webhook endpoint
PORT=3000

# Secret token validated via x-dynatrace-token header (set in Dynatrace notification custom headers)
# Leave unset to disable token validation (not recommended for production)
DYNATRACE_WEBHOOK_TOKEN=your_secret_token_here

# Dynatrace Grail — used by the log poller
# Base URL of your Dynatrace environment (no trailing slash)
DT_ENV_URL=https://your-env-id.apps.dynatrace.com
# OAuth client credentials (Settings → OAuth clients → Create client, scope: storage:logs:read)
DT_CLIENT_ID=dt0s02.XXXXXXXXXXXXXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY
