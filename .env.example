MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_DB_NAME=incidents
MONGO_COLLECTION=incidents

# URL of incident-remediation-agent Azure Function HTTP trigger
# Example: https://incident-remediation-agent-fn.azurewebsites.net/api/processIncident
FUNCTION_APP_URL=https://your-function-app.azurewebsites.net/api/processIncident

# Function App host key (from Azure portal → Function App → App keys)
FUNCTION_APP_KEY=your_function_app_host_key_here

LOG_LEVEL=info

# HTTP server port for the Dynatrace webhook endpoint
PORT=3000

# Secret token validated via x-dynatrace-token header (set in Dynatrace notification custom headers)
# Leave unset to disable token validation (not recommended for production)
DYNATRACE_WEBHOOK_TOKEN=your_secret_token_here

# Dynatrace Grail log poller — OAuth client credentials
# Create OAuth client at myaccount.dynatrace.com with scopes: storage:logs:read storage:buckets:read
DT_ENV_URL=https://your-env-id.apps.dynatrace.com
DT_CLIENT_ID=dt0s02.XXXXXXXXXXXXXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# Azure Blob Storage checkpoint — persists last processed timestamp across restarts
# Use a separate container from dynatrace-log-forwarder (func-logfwd-python uses "checkpoints")
CHECKPOINT_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
CHECKPOINT_CONTAINER=dynatrace-poller-checkpoints
CHECKPOINT_BLOB=checkpoint.json

