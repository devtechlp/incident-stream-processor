# Copy to .env — or run C:\SolEng\POC\start-incident-local.ps1 -InitOnly

# MongoDB Atlas — incidents DB (NOT freight_planning)
MONGO_URI=mongodb+srv://USER:PASSWORD@incident-mgmt-dev.fpgopz5.mongodb.net/?appName=incident-mgmt-dev
MONGO_DB_NAME=incident_management
MONGO_COLLECTION=service_error_logs

# Local agent — env fallback when remediation_routing collection/doc is missing
FUNCTION_APP_URL=http://localhost:7071/api/processIncident
FUNCTION_APP_KEY=

# Per-service agent routing (MongoDB collection; read on every forward, no cache)
# REMEDIATION_ROUTING_COLLECTION=remediation_routing
#
# Optional Jira env vars — required only when a routing rule uses destination: "jira"
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=FPI
# JIRA_INCIDENT_ISSUETYPE_ID=
# JIRA_SERVICE_NAME_FIELD_ID=
#
# Portal visibility — use JSM customer-request API (recommended for Dynatrace auto-incidents):
# JIRA_SERVICE_DESK_ID=2
# JIRA_REQUEST_TYPE_ID=86
# Request type 86 = "Report an Issue" on FPI (find IDs via GET /rest/servicedeskapi/servicedesk)

LOG_LEVEL=info
PORT=3000

# GitHub — two different secrets (both used by incident-stream-processor):
#
# 1) GITHUB_WEBHOOK_SECRET — shared secret with GitHub org webhook (incoming).
#    Register the SAME value in GitHub → Organization Settings → Webhooks → Secret.
#    Pass on deploy: -GithubWebhookSecret "..." (or omit to reuse existing container value / auto-generate).
#
# 2) GITHUB_TOKEN — GitHub PAT (outgoing API calls from the stream processor).
#    Pass on deploy: -GithubToken "ghp_..." (same pattern as -DtClientSecret).
#    Used for PR commit lookup, empty-Copilot-PR recheck, and AI credits after-snapshot.
#    Needs repo + org billing read (manage_billing:copilot) when COPILOT_BILLING_MODE=ai_credits.
GITHUB_WEBHOOK_SECRET=

GITHUB_TOKEN=
GITHUB_ORG=your-github-org

# Copilot billing — snapshot before assign / after PR via GitHub billing API (default: ai_credits)
# COPILOT_BILLING_MODE=ai_credits
# COPILOT_CREDIT_USD_RATE=0.01
# COPILOT_MODEL=claude-sonnet-5
# COPILOT_BILLING_PRODUCT=copilot

# Empty Copilot PR recheck delay in ms (default: 300000 = 5 minutes)
# COPILOT_PR_RECHECK_MS=300000

# Optional: manual PATCH /api/incidents/:id/status (debug only)
INTERNAL_API_KEY=

# Dynatrace Grail poller — required for hybrid mode (Azure log-forwarder → Grail → local poller)
DT_ENV_URL=https://your-env-id.apps.dynatrace.com
DT_CLIENT_ID=dt0s02.XXXXXXXXXXXXXXXXXXXX
DT_CLIENT_SECRET=dt0s02.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY

# Checkpoint in Azure Blob (same storage account as deployed stack)
CHECKPOINT_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=stincidentremediation;AccountKey=...;EndpointSuffix=core.windows.net
CHECKPOINT_CONTAINER=dynatrace-poller-checkpoints
CHECKPOINT_BLOB=checkpoint.json

# Optional webhook path (usually not needed in hybrid mode)
# DYNATRACE_WEBHOOK_TOKEN=
